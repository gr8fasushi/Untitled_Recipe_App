rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: validates required fields and types for a UserProfile document
    function validateUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'allergens',
                                  'dietaryPreferences', 'onboardingComplete', 'createdAt'])
        && data.uid is string
        && data.email is string
        && data.allergens is list
        && data.dietaryPreferences is list
        && data.onboardingComplete is bool;
    }

    // DENY ALL by default — explicit rules required per collection.
    // This is intentional. Rules will be added per feature as they are built.
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection — each user can only read/write their own document
    match /users/{uid} {
      // Read own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Create profile on sign-up — must be authenticated, uid must match
      allow create: if request.auth != null
        && request.auth.uid == uid
        && validateUserProfile(request.resource.data);

      // Update own profile — uid, createdAt, tier, and subscriptionExpiresAt are immutable (admin SDK only)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.get('tier', 'free') == resource.data.get('tier', 'free')
        && request.resource.data.get('subscriptionExpiresAt', null) == resource.data.get('subscriptionExpiresAt', null)
        && validateUserProfile(request.resource.data);

      // Delete own profile — required for App Store account deletion compliance
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Pantry subcollection — single doc per user: users/{uid}/pantry/items
      match /pantry/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Grocery list subcollection — single doc per user: users/{uid}/groceryList/items
      match /groceryList/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Saved recipes subcollection — private to each user
      match /savedRecipes/{recipeId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Shared (community) recipes — readable by all authenticated users
    // Only the original sharer can delete; anyone authenticated can create or update (for saveCount)
    match /sharedRecipes/{recipeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.sharedBy.uid;
    }

    // Shared ingredient cache — any authenticated user can read or write
    // Stores safe metadata only: id, name, category, emoji, cachedAt
    match /ingredients/{ingredientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Rate limit counters — only writable by authenticated Cloud Functions
    // (Cloud Functions use admin SDK which bypasses security rules)
    match /rateLimits/{uid}/{operation}/{window} {
      allow read: if false;
      allow write: if false;
    }

    // Daily usage counters — owner can read (to show progress UI), only CF admin SDK can write
    match /dailyLimits/{uid}/{operation}/{day} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
