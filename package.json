{
  "name": "recipeapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "kill-port": "kill-port 8081 || true",
    "start": "npm run kill-port && cross-env EXPO_ROUTER_APP_ROOT=src/app EXPO_PUBLIC_FIREBASE_ENV=staging expo start --port 8081",
    "start:local": "npm run kill-port && cross-env EXPO_ROUTER_APP_ROOT=src/app expo start --port 8081",
    "android": "npm run kill-port && cross-env EXPO_ROUTER_APP_ROOT=src/app EXPO_PUBLIC_FIREBASE_ENV=staging expo start --android --port 8081",
    "ios": "npm run kill-port && cross-env EXPO_ROUTER_APP_ROOT=src/app EXPO_PUBLIC_FIREBASE_ENV=staging expo start --ios --port 8081",
    "web": "npm run kill-port && cross-env EXPO_ROUTER_APP_ROOT=src/app EXPO_PUBLIC_FIREBASE_ENV=staging expo start --web --port 8081",
    "test": "jest",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.0",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.9.0",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest-expo": "^54.0.17",
    "kill-port": "^2.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
