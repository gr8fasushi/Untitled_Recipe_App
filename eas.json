{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENV": "local",
        "EXPO_ROUTER_APP_ROOT": "src/app"
      }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENV": "staging",
        "EXPO_ROUTER_APP_ROOT": "src/app"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENV": "production",
        "EXPO_ROUTER_APP_ROOT": "src/app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
